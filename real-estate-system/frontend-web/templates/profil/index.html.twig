{% extends 'base.html.twig' %}

{% block title %}Mon Profil{% endblock %}

{% block stylesheets %}
<style>
    .profile-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 2rem;
    }
    .profile-avatar {
        width: 56px;
        height: 56px;
        border-radius: 9999px;
        background: #0f172a;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 1.125rem;
        flex-shrink: 0;
        letter-spacing: -0.5px;
    }
    .profile-header-text h1 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #0f172a;
        letter-spacing: -0.5px;
        line-height: 1.3;
    }
    .profile-header-text p {
        color: #64748b;
        font-size: 0.875rem;
        margin-top: 0.25rem;
    }
    .profile-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
        margin-bottom: 1.5rem;
    }
    .profile-card {
        background: #fff;
        border-radius: 8px;
        border: 1px solid #e2e8f0;
        overflow: hidden;
    }
    .profile-card-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 1rem 1.5rem;
        border-bottom: 1px solid #e2e8f0;
        font-size: 1.125rem;
        font-weight: 700;
        color: #0f172a;
    }
    .profile-card-header svg { color: #94a3b8; }
    .profile-card-body {
        padding: 1.5rem;
    }
    .profile-card.full-width {
        grid-column: 1 / -1;
    }
    .profile-hint {
        font-size: 0.75rem;
        color: #94a3b8;
        margin-top: 0.25rem;
    }
    .profile-actions {
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    .account-info-row {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.625rem 0;
    }
    .account-info-row + .account-info-row {
        border-top: 1px solid #f1f5f9;
    }
    .account-info-label {
        font-size: 0.8125rem;
        color: #94a3b8;
        min-width: 80px;
    }
    .account-info-value {
        font-size: 0.875rem;
        color: #0f172a;
        font-weight: 500;
    }
    .role-badge {
        display: inline-block;
        padding: 0.125rem 0.5rem;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .role-badge-super { background: #fef3c7; color: #92400e; }
    .role-badge-admin { background: #dbeafe; color: #1e40af; }
    .role-badge-agent { background: #e0e7ff; color: #3730a3; }
    .role-badge-client { background: #d1fae5; color: #065f46; }
    .password-section {
        margin-top: 2rem;
        padding-top: 2rem;
        border-top: 1px solid #e2e8f0;
    }
    .password-section h2 {
        font-size: 1.125rem;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 0.25rem;
    }
    .password-section > p {
        font-size: 0.875rem;
        color: #64748b;
        margin-bottom: 1.5rem;
    }
    .password-form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 1rem;
        margin-bottom: 1rem;
    }
    @media (max-width: 768px) {
        .profile-grid { grid-template-columns: 1fr; }
        .password-form-grid { grid-template-columns: 1fr; }
    }
</style>
{% endblock %}

{% block body %}
<div class="profile-header">
    <div class="profile-avatar">
        {{ (personne.prenom ?? 'U')|slice(0,1)|upper }}{{ (personne.nom ?? '')|slice(0,1)|upper }}
    </div>
    <div class="profile-header-text">
        <h1>{{ personne.prenom ?? '' }} {{ personne.nom ?? '' }}</h1>
        <p>Gerez vos informations personnelles</p>
    </div>
</div>

<form method="POST">
    <div class="profile-grid">
        {# === Account Info (read-only) === #}
        <div class="profile-card full-width">
            <div class="profile-card-header">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                Compte
            </div>
            <div class="profile-card-body">
                <div class="account-info-row">
                    <span class="account-info-label">Email</span>
                    <span class="account-info-value">{{ account.email ?? 'Non renseigne' }}</span>
                </div>
                <div class="account-info-row">
                    <span class="account-info-label">Role</span>
                    <span class="account-info-value">
                        {% set role = account.role ?? 'CLIENT' %}
                        {% if role == 'SUPER_ADMIN' %}
                            <span class="role-badge role-badge-super">Super Admin</span>
                        {% elseif role == 'ADMIN_AGENCY' %}
                            <span class="role-badge role-badge-admin">Admin Agence</span>
                        {% elseif role == 'AGENT' %}
                            <span class="role-badge role-badge-agent">Agent</span>
                        {% else %}
                            <span class="role-badge role-badge-client">Client</span>
                        {% endif %}
                    </span>
                </div>
                {% if account.agenceNom is defined and account.agenceNom %}
                <div class="account-info-row">
                    <span class="account-info-label">Agence</span>
                    <span class="account-info-value">{{ account.agenceNom }}</span>
                </div>
                {% endif %}
            </div>
        </div>

        {# === Identity === #}
        <div class="profile-card">
            <div class="profile-card-header">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                Identite
            </div>
            <div class="profile-card-body">
                <div class="form-row">
                    <div class="form-group">
                        <label>Prenom *</label>
                        <input type="text" name="prenom" value="{{ personne.prenom ?? '' }}" required>
                    </div>
                    <div class="form-group">
                        <label>Nom *</label>
                        <input type="text" name="nom" value="{{ personne.nom ?? '' }}" required>
                    </div>
                </div>
                <div class="form-group">
                    <label>Date de naissance</label>
                    <input type="date" name="dateNais" value="{{ personne.dateNais ?? '' }}">
                </div>
            </div>
        </div>

        {# === Address === #}
        <div class="profile-card">
            <div class="profile-card-header">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                Adresse
            </div>
            <div class="profile-card-body">
                <div class="form-group">
                    <label>Rue</label>
                    <input type="text" name="rue" value="{{ personne.rue ?? '' }}" placeholder="12 rue de la Paix">
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Ville</label>
                        <input type="text" name="ville" value="{{ personne.ville ?? '' }}" placeholder="Paris">
                    </div>
                    <div class="form-group">
                        <label>Code postal</label>
                        <input type="text" name="codePostal" value="{{ personne.codePostal ?? '' }}" placeholder="75001">
                    </div>
                </div>
            </div>
        </div>

        {# === Banking === #}
        <div class="profile-card full-width">
            <div class="profile-card-header">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 10H2"/><path d="M6 14h.01"/><path d="M10 14h.01"/></svg>
                Coordonnees bancaires
            </div>
            <div class="profile-card-body">
                <div class="form-group">
                    <label>IBAN / RIB</label>
                    <input type="text" name="rib" value="{{ personne.rib ?? '' }}" placeholder="FR76 1234 5678 9012 3456 7890 123" maxlength="34">
                    <p class="profile-hint">Utilise pour les versements de loyers et revenus de vente.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="profile-actions">
        <button type="submit" class="btn btn-primary">Enregistrer les modifications</button>
        {% set user = app.session.get('user') %}
        {% if user.role is defined and user.role == 'CLIENT' %}
            <a href="{{ path('client_dashboard') }}" class="btn btn-secondary">Retour</a>
        {% else %}
            <a href="{{ path('admin_dashboard') }}" class="btn btn-secondary">Retour</a>
        {% endif %}
    </div>
</form>

{# === Password Change Section === #}
<div class="password-section">
    <h2>Changer le mot de passe</h2>
    <p>Modifiez votre mot de passe de connexion. Minimum 8 caracteres.</p>
    <form method="POST" action="{{ path('profil_change_password') }}">
        <div class="password-form-grid">
            <div class="form-group">
                <label>Mot de passe actuel *</label>
                <input type="password" name="currentPassword" required autocomplete="current-password">
            </div>
            <div class="form-group">
                <label>Nouveau mot de passe *</label>
                <input type="password" name="newPassword" required minlength="8" autocomplete="new-password">
            </div>
            <div class="form-group">
                <label>Confirmer le mot de passe *</label>
                <input type="password" name="confirmPassword" required minlength="8" autocomplete="new-password">
            </div>
        </div>
        <button type="submit" class="btn btn-primary">Changer le mot de passe</button>
    </form>
</div>
{% endblock %}
