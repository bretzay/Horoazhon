{% extends 'base.html.twig' %}

{% block title %}Parametres de l'agence{% endblock %}

{% block stylesheets %}
<style>
    .settings-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
        margin-bottom: 1.5rem;
    }
    .settings-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        padding: 1.5rem;
    }
    .settings-card h3 {
        font-size: 1.125rem;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 1.25rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid #f1f5f9;
    }
    .settings-card.full-width {
        grid-column: 1 / -1;
    }
    .logo-preview {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 1rem;
    }
    .logo-preview img {
        width: 96px;
        height: 96px;
        border-radius: 16px;
        object-fit: cover;
        border: 1px solid #e2e8f0;
        background: #f1f5f9;
    }
    .logo-placeholder {
        width: 96px;
        height: 96px;
        border-radius: 16px;
        background: #f1f5f9;
        border: 2px dashed #e2e8f0;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #94a3b8;
        flex-shrink: 0;
    }
    .logo-info {
        flex: 1;
    }
    .logo-info p {
        font-size: 0.875rem;
        color: #64748b;
        margin-bottom: 0.5rem;
    }
    .info-row {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.5rem 0;
        border-bottom: 1px solid #f1f5f9;
    }
    .info-row:last-child { border-bottom: none; }
    .info-label {
        font-size: 0.75rem;
        font-weight: 500;
        color: #94a3b8;
        min-width: 100px;
    }
    .info-value {
        font-size: 0.875rem;
        color: #334155;
    }
    textarea {
        width: 100%;
        min-height: 120px;
        padding: 0.75rem;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        font-family: inherit;
        font-size: 0.875rem;
        resize: vertical;
        transition: border-color 0.2s;
    }
    textarea:focus {
        outline: none;
        border-color: #2563eb;
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
    }
    @media (max-width: 768px) {
        .settings-grid { grid-template-columns: 1fr; }
    }
</style>
{% endblock %}

{% block body %}
<div class="page-header">
    <div>
        <h1>Parametres de l'agence</h1>
        <p style="color: #64748b; font-size: 0.875rem;">Personnalisez le profil de votre agence</p>
    </div>
    <a href="{{ path('admin_dashboard') }}" class="btn btn-secondary">Retour</a>
</div>

<form method="POST" enctype="multipart/form-data">
    <div class="settings-grid">
        {# === Identity Card === #}
        <div class="settings-card">
            <h3>Identite</h3>
            <div class="form-group">
                <label>Nom de l'agence *</label>
                <input type="text" name="nom" value="{{ agence.nom ?? '' }}" required>
            </div>
            <div class="form-group">
                <label>Description</label>
                <textarea name="description" placeholder="Decrivez votre agence, vos specialites, votre zone d'intervention...">{{ agence.description ?? '' }}</textarea>
            </div>
        </div>

        {# === Logo Card === #}
        <div class="settings-card">
            <h3>Logo</h3>
            <div class="logo-preview">
                {% if agence.logo is defined and agence.logo %}
                    <img id="logoPreviewImg" src="{{ agence.logo }}" alt="Logo {{ agence.nom }}">
                {% else %}
                    <div class="logo-placeholder" id="logoPlaceholder">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                    </div>
                    <img id="logoPreviewImg" style="display:none; width:96px; height:96px; border-radius:16px; object-fit:cover; border:1px solid #e2e8f0;">
                {% endif %}
                <div class="logo-info">
                    <p>Format recommande : PNG ou JPG, carre (1:1). L'image sera recadree automatiquement.</p>
                    <input type="file" name="logo_file" accept="image/png,image/jpeg,image/webp" id="logoFileInput">
                </div>
            </div>
        </div>

        {# === Contact Info (read-only) === #}
        <div class="settings-card full-width">
            <h3>Informations de l'agence</h3>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0 2rem;">
                <div>
                    <div class="info-row">
                        <span class="info-label">SIRET</span>
                        <span class="info-value">{{ agence.siret ?? '-' }}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">N TVA</span>
                        <span class="info-value">{{ agence.numeroTva ?? '-' }}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Adresse</span>
                        <span class="info-value">{{ agence.rue ?? '' }}, {{ agence.codePostal ?? '' }} {{ agence.ville ?? '' }}</span>
                    </div>
                </div>
                <div>
                    <div class="info-row">
                        <span class="info-label">Telephone</span>
                        <span class="info-value">{{ agence.telephone ?? '-' }}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Email</span>
                        <span class="info-value">{{ agence.email ?? '-' }}</span>
                    </div>
                </div>
            </div>
            <p style="font-size: 0.75rem; color: #94a3b8; margin-top: 1rem;">Pour modifier les informations administratives, contactez un super-administrateur.</p>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Enregistrer les modifications</button>
</form>

<script>
document.getElementById('logoFileInput').addEventListener('change', function(e) {
    var file = e.target.files[0];
    if (!file) return;
    var reader = new FileReader();
    reader.onload = function(ev) {
        var img = document.getElementById('logoPreviewImg');
        img.src = ev.target.result;
        img.style.display = '';
        var placeholder = document.getElementById('logoPlaceholder');
        if (placeholder) placeholder.style.display = 'none';
    };
    reader.readAsDataURL(file);
});
</script>
{% endblock %}
