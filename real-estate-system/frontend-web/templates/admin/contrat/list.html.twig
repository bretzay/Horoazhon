{% extends 'base.html.twig' %}

{% block title %}Admin - Contrats{% endblock %}

{% block body %}
<div class="page-header">
    <h1>Gestion des Contrats</h1>
    <a href="{{ path('admin_contrats_new') }}" class="btn btn-primary">+ Nouveau Contrat</a>
</div>

<form method="GET" class="filters" style="display:flex;gap:1rem;align-items:flex-end;margin-bottom:1rem;">
    <div class="form-group" style="margin-bottom:0;">
        <label>Type</label>
        <select name="type" style="padding:0.5rem;border-radius:6px;border:1px solid #e2e8f0;">
            <option value="">Tous</option>
            <option value="LOCATION"{{ app.request.query.get('type') == 'LOCATION' ? ' selected' : '' }}>Location</option>
            <option value="ACHAT"{{ app.request.query.get('type') == 'ACHAT' ? ' selected' : '' }}>Achat</option>
        </select>
    </div>
    <div class="form-group" style="margin-bottom:0;">
        <label>Statut</label>
        <select name="statut" style="padding:0.5rem;border-radius:6px;border:1px solid #e2e8f0;">
            <option value="">Tous</option>
            <option value="EN_COURS"{{ app.request.query.get('statut') == 'EN_COURS' ? ' selected' : '' }}>En cours</option>
            <option value="SIGNE"{{ app.request.query.get('statut') == 'SIGNE' ? ' selected' : '' }}>Signe</option>
            <option value="ANNULE"{{ app.request.query.get('statut') == 'ANNULE' ? ' selected' : '' }}>Annule</option>
            <option value="TERMINE"{{ app.request.query.get('statut') == 'TERMINE' ? ' selected' : '' }}>Termine</option>
        </select>
    </div>
    <button type="submit" class="btn btn-primary btn-sm">Filtrer</button>
    {% if app.request.query.get('type') or app.request.query.get('statut') %}
        <a href="{{ path('admin_contrats') }}" class="btn btn-secondary btn-sm">Reset</a>
    {% endif %}
</form>

<table>
    <thead>
        <tr><th>ID</th><th>Type</th><th>Bien</th><th>Montant</th><th>Statut</th><th>Cosignataires</th><th>Date</th><th>Actions</th></tr>
    </thead>
    <tbody>
        {% for c in contrats %}
        <tr>
            <td>CTR-{{ c.id }}</td>
            <td><span class="badge {{ c.type == 'ACHAT' ? 'badge-sale' : 'badge-rent' }}">{{ c.type }}</span></td>
            <td>{% if c.bien %}{{ c.bien.type ?? '' }} - {{ c.bien.rue ?? '' }}, {{ c.bien.ville ?? '' }}{% else %}-{% endif %}</td>
            <td>
                {% if c.type == 'ACHAT' and c.snapPrix is defined and c.snapPrix %}
                    {{ c.snapPrix|number_format(0, ',', ' ') }} &euro;
                {% elseif c.type == 'LOCATION' and c.snapMensualite is defined and c.snapMensualite %}
                    {{ c.snapMensualite|number_format(0, ',', ' ') }} &euro;/mois
                {% else %}
                    -
                {% endif %}
            </td>
            <td><span class="badge badge-{{ c.statut|lower }}">{{ c.statut }}</span></td>
            <td>
                {% if c.cosigners %}
                    {% for cs in c.cosigners %}{{ cs.prenom }} {{ cs.nom }} ({{ cs.typeSignataire }}){% if not loop.last %}, {% endif %}{% endfor %}
                {% endif %}
            </td>
            <td>{{ c.dateCreation|slice(0, 10) }}</td>
            <td><a href="{{ path('admin_contrats_detail', {id: c.id}) }}" class="btn btn-primary btn-sm">Detail</a></td>
        </tr>
        {% else %}
        <tr><td colspan="8">Aucun contrat.</td></tr>
        {% endfor %}
    </tbody>
</table>

{% if totalPages > 1 %}
<div class="pagination">
    {% for i in 0..totalPages-1 %}
        {% if i == currentPage %}
            <span class="current">{{ i + 1 }}</span>
        {% else %}
            <a href="{{ path('admin_contrats', {page: i}) }}">{{ i + 1 }}</a>
        {% endif %}
    {% endfor %}
</div>
{% endif %}
{% endblock %}
