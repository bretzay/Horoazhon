{% extends 'base.html.twig' %}

{% block title %}Admin - Nouveau Contrat{% endblock %}

{% block stylesheets %}
<style>
    .autocomplete-wrapper { position: relative; }
    .autocomplete-results { position: absolute; top: 100%; left: 0; right: 0; background: #fff; border: 1px solid #e2e8f0; border-top: none; border-radius: 0 0 4px 4px; max-height: 200px; overflow-y: auto; z-index: 50; display: none; box-shadow: 0 4px 6px rgba(15,23,42,0.10); }
    .autocomplete-results.active { display: block; }
    .autocomplete-item { padding: 0.5rem 0.75rem; cursor: pointer; font-size: 0.875rem; }
    .autocomplete-item:hover { background: #f1f5f9; }
    .autocomplete-item .sub { font-size: 0.75rem; color: #94a3b8; }
    .offer-info { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; padding: 1rem; margin-top: 0.75rem; }
    .offer-info .offer-row { display: flex; justify-content: space-between; padding: 0.25rem 0; font-size: 0.875rem; }
    .offer-info .offer-label { color: #94a3b8; }
    .offer-info .offer-value { font-weight: 600; color: #0f172a; }
</style>
{% endblock %}

{% block body %}
<div class="page-header">
    <h1>Nouveau Contrat</h1>
    <a href="{{ path('admin_contrats') }}" class="btn btn-secondary">Retour</a>
</div>

<div class="card">
    <form method="POST">
        <div class="form-group">
            <label>Type de contrat *</label>
            <div style="display: flex; gap: 1rem; margin-top: 0.25rem;">
                <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-weight: normal;">
                    <input type="radio" name="contractType" value="ACHAT" onchange="onTypeChange()" required> Achat (Vente)
                </label>
                <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-weight: normal;">
                    <input type="radio" name="contractType" value="LOCATION" onchange="onTypeChange()" required> Location
                </label>
            </div>
        </div>

        <div class="form-group" id="bienSelectGroup" style="display:none;">
            <label>Bien *</label>
            <select name="bienId" id="bienId" onchange="onBienChange()" required>
                <option value="">-- Choisir un bien --</option>
            </select>
            <div id="offerInfo" style="display:none;"></div>
        </div>

        <div id="partiesSection" data-section="cosignataires" style="display:none;">
            <h3 style="margin: 1.5rem 0 0.75rem;">Cosignataires</h3>

            <div class="form-group">
                <label id="sellerLabel">Vendeur</label>
                <input type="text" id="ownerDisplay" readonly style="background: #f1f5f9; cursor: not-allowed;" value="">
                <small id="sellerRole" class="form-text" style="color: #64748b; font-size: 0.75rem;">Rôle : <span id="sellerRoleText">VENDEUR</span></small>
            </div>

            <div class="form-group autocomplete-wrapper">
                <label id="buyerLabel"></label>
                <input type="hidden" name="buyer_personne" id="buyerHidden" required>
                <input type="text" id="buyerSearch" autocomplete="off" placeholder="Rechercher par nom ou prenom...">
                <div class="autocomplete-results" id="buyerResults"></div>
                <small id="buyerRole" class="form-text" style="color: #64748b; font-size: 0.75rem;">Rôle : <span id="buyerRoleText">ACHETEUR</span></small>
            </div>

            <div style="margin-top: 1rem;">
                <button type="submit" class="btn btn-primary">Creer le contrat</button>
            </div>
        </div>
    </form>
</div>
{% endblock %}

{% block javascripts %}
<script>
var allBiens = {{ biens|json_encode|raw }};
var bienOwners = {{ bienOwners|json_encode|raw }};
var searchUrl = '{{ path("admin_personnes_search_json") }}';
var currentType = '';
var currentOwnerId = null;

function formatPrice(value) {
    if (!value) return '-';
    return Number(value).toLocaleString('fr-FR') + ' \u20ac';
}

function setupAutocomplete(inputEl, hiddenEl, resultsEl) {
    var timer = null;
    inputEl.addEventListener('input', function() {
        hiddenEl.value = '';
        var q = this.value.trim();
        clearTimeout(timer);
        if (q.length < 1) { resultsEl.classList.remove('active'); return; }
        timer = setTimeout(function() {
            fetch(searchUrl + '?q=' + encodeURIComponent(q))
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    while (resultsEl.firstChild) resultsEl.removeChild(resultsEl.firstChild);
                    var filtered = data.filter(function(p) { return p.id !== currentOwnerId; });
                    if (filtered.length === 0) {
                        var noResult = document.createElement('div');
                        noResult.className = 'autocomplete-item';
                        noResult.style.color = '#94a3b8';
                        noResult.textContent = 'Aucun resultat';
                        resultsEl.appendChild(noResult);
                    } else {
                        filtered.forEach(function(p) {
                            var div = document.createElement('div');
                            div.className = 'autocomplete-item';
                            var strong = document.createElement('strong');
                            strong.textContent = p.prenom + ' ' + p.nom;
                            div.appendChild(strong);
                            if (p.ville) {
                                var sub = document.createElement('div');
                                sub.className = 'sub';
                                sub.textContent = p.ville;
                                div.appendChild(sub);
                            }
                            div.addEventListener('click', function() {
                                inputEl.value = p.prenom + ' ' + p.nom;
                                hiddenEl.value = p.id;
                                resultsEl.classList.remove('active');
                            });
                            resultsEl.appendChild(div);
                        });
                    }
                    resultsEl.classList.add('active');
                });
        }, 250);
    });

    document.addEventListener('click', function(e) {
        if (!inputEl.contains(e.target) && !resultsEl.contains(e.target)) {
            resultsEl.classList.remove('active');
        }
    });
}

setupAutocomplete(
    document.getElementById('buyerSearch'),
    document.getElementById('buyerHidden'),
    document.getElementById('buyerResults')
);

function onTypeChange() {
    var radios = document.querySelectorAll('input[name="contractType"]');
    currentType = '';
    radios.forEach(function(r) { if (r.checked) currentType = r.value; });

    var select = document.getElementById('bienId');
    while (select.options.length > 1) select.remove(1);

    allBiens.forEach(function(b) {
        var show = false;
        if (currentType === 'ACHAT' && b.availableForSale) show = true;
        if (currentType === 'LOCATION' && b.availableForRent) show = true;
        if (show) {
            var price = currentType === 'ACHAT'
                ? (b.salePrice ? formatPrice(b.salePrice) : '')
                : (b.monthlyRent ? formatPrice(b.monthlyRent) + '/mois' : '');
            var opt = document.createElement('option');
            opt.value = b.id;
            opt.textContent = b.type + ' - ' + b.rue + ', ' + b.ville + (price ? ' (' + price + ')' : '');
            select.appendChild(opt);
        }
    });

    document.getElementById('bienSelectGroup').style.display = currentType ? 'block' : 'none';
    document.getElementById('sellerLabel').textContent = currentType === 'LOCATION' ? 'Proprietaire' : 'Vendeur';
    document.getElementById('buyerLabel').textContent = currentType === 'LOCATION' ? 'Locataire *' : 'Acheteur *';
    document.getElementById('sellerRoleText').textContent = currentType === 'LOCATION' ? 'PROPRIETAIRE' : 'VENDEUR';
    document.getElementById('buyerRoleText').textContent = currentType === 'LOCATION' ? 'LOCATAIRE' : 'ACHETEUR';
    document.getElementById('offerInfo').style.display = 'none';
    document.getElementById('partiesSection').style.display = 'none';
    document.getElementById('ownerDisplay').value = '';
    currentOwnerId = null;
}

function onBienChange() {
    var bienId = document.getElementById('bienId').value;
    var infoDiv = document.getElementById('offerInfo');
    currentOwnerId = null;

    if (!bienId) {
        infoDiv.style.display = 'none';
        document.getElementById('partiesSection').style.display = 'none';
        document.getElementById('ownerDisplay').value = '';
        return;
    }

    var bien = allBiens.find(function(b) { return b.id == bienId; });
    if (!bien) return;

    // Build offer info using safe DOM methods
    infoDiv.textContent = '';
    var wrapper = document.createElement('div');
    wrapper.className = 'offer-info';
    var title = document.createElement('div');
    title.style.fontWeight = '600';
    title.style.marginBottom = '0.5rem';
    title.textContent = 'Valeurs de l\'offre actuelle';
    wrapper.appendChild(title);

    function addRow(label, value) {
        var row = document.createElement('div');
        row.className = 'offer-row';
        var lbl = document.createElement('span');
        lbl.className = 'offer-label';
        lbl.textContent = label;
        var val = document.createElement('span');
        val.className = 'offer-value';
        val.textContent = value;
        row.appendChild(lbl);
        row.appendChild(val);
        wrapper.appendChild(row);
    }

    if (currentType === 'ACHAT') {
        addRow('Prix de vente', bien.salePrice ? formatPrice(bien.salePrice) : '-');
    } else {
        addRow('Loyer mensuel', bien.monthlyRent ? formatPrice(bien.monthlyRent) + '/mois' : '-');
    }

    infoDiv.appendChild(wrapper);
    infoDiv.style.display = 'block';

    // Show owner
    var owner = bienOwners[bienId];
    if (owner) {
        document.getElementById('ownerDisplay').value = owner.prenom + ' ' + owner.nom;
        currentOwnerId = owner.personneId;
    } else {
        document.getElementById('ownerDisplay').value = 'Aucun proprietaire defini';
    }

    document.getElementById('partiesSection').style.display = 'block';
}

// Auto-select from query params
(function() {
    var preBienId = '{{ preselectedBienId ?? '' }}';
    var preType = '{{ preselectedType ?? '' }}';
    if (preType && preBienId) {
        var radio = document.querySelector('input[name="contractType"][value="' + preType + '"]');
        if (radio) {
            radio.checked = true;
            onTypeChange();
            document.getElementById('bienId').value = preBienId;
            onBienChange();
        }
    }
})();

// Validate signers before submit
document.querySelector('form').addEventListener('submit', function(e) {
    var buyerHidden = document.getElementById('buyerHidden');
    if (!buyerHidden.value) {
        e.preventDefault();
        alert('Veuillez selectionner un signataire valide depuis la liste.');
    }
});
</script>
{% endblock %}